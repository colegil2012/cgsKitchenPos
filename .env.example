# Copy to `.env`. Vite inlines these at BUILD time (vue build), so rebuild
# after changing. On the kiosk that means: edit .env, npm run build, the
# update.sh git-pull picks up the new dist/.

# Backend base URL as seen from the POS Pi. LAN IP, no trailing slash.
VITE_API_BASE_URL=http://192.168.1.50:8080

# Value of app.api-key on the server. Required for order create + status.
VITE_API_KEY=changeme

# Recorded as the actor on status transitions.
VITE_POS_ACTOR=pos-1
